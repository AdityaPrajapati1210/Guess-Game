<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎯 Guess The Number</title>

    <link rel="stylesheet" href="stylesheets/index.css">
</head>
<body>

    <h1 class="heading">🎯 GUESS THE NUMBER 🎯</h1>

    <div class="rules">
        <h2>📜 Game Rules</h2>
        <p>🎲 Enter your own number range.</p>
        <p>🤔 Guess the hidden number.</p>
        <p>📈 Get hints after every guess.</p>
        <p>🏆 Win in the fewest attempts!</p>
    </div>

    <div class="container">

        <div class="game-icon">🎮</div>

        <h2>Start New Game</h2>

        <p class="subtitle">
            Can you find the hidden number?
        </p>

        <form action="/start" method="POST">

            <div class="range">

                <div class="box">
                    <label>From</label>
                    <input type="number" name="from" required>
                </div>

                <div class="box">
                    <label>To</label>
                    <input type="number" name="to" required>
                </div>

            </div>

            <input type="submit" value="🚀 START GAME">

        </form>

    </div>

    <div class="difficulty">
        <h2>⚡ Challenge Levels</h2>
        <p>😊 Easy : 1 - 10</p>
        <p>😎 Medium : 1 - 100</p>
        <p>🔥 Hard : 1 - 1000</p>
        <p>💀 Extreme : Any Range</p>
    </div>

    <!-- Floating Icons -->
    <div class="emoji e1">🎲</div>
    <div class="emoji e2">🎯</div>
    <div class="emoji e3">👑</div>
    <div class="emoji e4">💎</div>
    <div class="emoji e5">⭐</div>
    <div class="emoji e6">🎮</div>

    <!-- Bottom Quote -->
    <div class="quote">
        "Every Guess Brings You Closer to Victory! 🚀"
    </div>

</body>
</html>